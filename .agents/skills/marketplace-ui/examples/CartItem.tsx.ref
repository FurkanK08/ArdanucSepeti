import React from 'react';
import { View, Image, TextInput, StyleSheet, Text, TouchableOpacity } from 'react-native';

/**
 * CartItem - Checkout ekranındaki Sepet Ögesi
 * Kaynak: docs/ui-designs/checkout_screen/code.html
 * - Sol küçük resim (80x80, borderRadius: 12)
 * - Orta: ürün adı (bold siyah) + fiyat (bold turuncu)
 * - Sağ alt: +/- quantity kontrolü (oval pill, primary ile +)
 */
export const CartItem = ({
  name,
  price,
  imageUrl,
  quantity,
  onIncrease,
  onDecrease,
}: {
  name: string;
  price: number;
  imageUrl: string;
  quantity: number;
  onIncrease: () => void;
  onDecrease: () => void;
}) => {
  return (
    <View style={styles.card}>
      {/* Thumbnail */}
      <Image source={{ uri: imageUrl }} style={styles.thumbnail} />
      {/* Info */}
      <View style={styles.info}>
        <View style={styles.titleRow}>
          <Text style={styles.name}>{name}</Text>
          <Text style={styles.price}>{price} TL</Text>
        </View>
        {/* Quantity Controls */}
        <View style={styles.quantityRow}>
          <View style={styles.quantityControls}>
            <TouchableOpacity style={styles.qBtnMinus} onPress={onDecrease}>
              <Text style={styles.qBtnText}>−</Text>
            </TouchableOpacity>
            <Text style={styles.qCount}>{quantity}</Text>
            <TouchableOpacity style={styles.qBtnPlus} onPress={onIncrease}>
              <Text style={styles.qBtnTextPlus}>+</Text>
            </TouchableOpacity>
          </View>
        </View>
      </View>
    </View>
  );
};

const styles = StyleSheet.create({
  card: {
    backgroundColor: '#ffffff',
    borderRadius: 16,
    padding: 16,
    flexDirection: 'row',
    alignItems: 'center',
    gap: 16,
    shadowColor: '#000',
    shadowOpacity: 0.03,
    shadowRadius: 4,
    elevation: 1,
    marginBottom: 12,
  },
  thumbnail: {
    width: 80,
    height: 80,
    borderRadius: 12,
  },
  info: {
    flex: 1,
    justifyContent: 'space-between',
    height: 80,
  },
  titleRow: {
    flexDirection: 'row',
    justifyContent: 'space-between',
    alignItems: 'flex-start',
  },
  name: {
    fontSize: 16,
    fontWeight: '700',
    color: '#191c1e',
    flex: 1,
    lineHeight: 20,
  },
  price: {
    fontSize: 16,
    fontWeight: '700',
    color: '#a93100',
  },
  quantityRow: {
    flexDirection: 'row',
    justifyContent: 'flex-end',
  },
  quantityControls: {
    flexDirection: 'row',
    alignItems: 'center',
    backgroundColor: '#f2f4f6',
    borderRadius: 9999,
    padding: 4,
    gap: 16,
  },
  qBtnMinus: {
    width: 28,
    height: 28,
    borderRadius: 14,
    backgroundColor: '#ffffff',
    alignItems: 'center',
    justifyContent: 'center',
  },
  qBtnPlus: {
    width: 28,
    height: 28,
    borderRadius: 14,
    backgroundColor: '#a93100',
    alignItems: 'center',
    justifyContent: 'center',
  },
  qBtnText: {
    fontSize: 16,
    fontWeight: '700',
    color: '#191c1e',
  },
  qBtnTextPlus: {
    fontSize: 16,
    fontWeight: '700',
    color: '#ffffff',
  },
  qCount: {
    fontSize: 14,
    fontWeight: '700',
    color: '#191c1e',
    width: 16,
    textAlign: 'center',
  },
});
